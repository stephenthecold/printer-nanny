# Copy to .env and adjust. The app reads these via central/config.py.

# Database. Leave unset to use a local SQLite file (dev/tests).
# Production (Docker Compose) uses Postgres:
# DATABASE_URL=postgresql+psycopg://nanny:nanny@db:5432/printer_nanny
DATABASE_URL=sqlite:///./printer_nanny.sqlite3

# Session signing secret for the dashboard. CHANGE THIS in production.
SECRET_KEY=dev-insecure-change-me

# How long (seconds) without a heartbeat before an agent is marked offline.
AGENT_OFFLINE_GRACE_SECONDS=300

# --- Email channel (SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=printer-nanny@example.com
SMTP_USE_TLS=false

# --- FreeScout channel ---
# Base URL of your FreeScout install and an API key from the API & Webhooks module.
FREESCOUT_BASE_URL=
FREESCOUT_API_KEY=
FREESCOUT_MAILBOX_ID=1

# --- Microsoft Teams channel (stub for now) ---
TEAMS_WEBHOOK_URL=
