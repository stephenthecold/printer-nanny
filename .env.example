# Copy to .env. Only these two are needed — everything else (SMTP, FreeScout,
# alert thresholds, polling intervals, SNMP defaults, SSO) is managed in the UI
# under Settings and stored in the database.

# Leave unset to use a local SQLite file (dev/tests). Production (Docker Compose)
# uses Postgres:
# DATABASE_URL=postgresql+psycopg://nanny:nanny@db:5432/printer_nanny
DATABASE_URL=sqlite:///./printer_nanny.sqlite3

# Session signing secret for the dashboard. CHANGE THIS in production.
SECRET_KEY=dev-insecure-change-me

# --- Optional bootstrap defaults ---------------------------------------------
# These seed the initial values on the Settings page the first time the app runs.
# After that, edit them in the UI (Settings) — no need to keep them here.
# AGENT_OFFLINE_GRACE_SECONDS=300
# SMTP_HOST=mailhog
# SMTP_PORT=1025
# SMTP_FROM=printer-nanny@example.com
